<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1080" d:DesignHeight="720"
        x:Class="PhotoManager.UI.Views.PieceStitchWindow"
        Width="1080" Height="720"
        MinWidth="820" MinHeight="540"
        WindowStartupLocation="CenterOwner"
        Title="Stitch torn pieces">
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="12">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
      <TextBlock Text="Stitch torn pieces" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Opacity="0.75" TextWrapping="Wrap"
                 Text="Load a single scan that contains several ripped pieces of one photograph laid out on a uniform white or black background. The pipeline detects each piece, matches torn edges across pieces, and emits a reassembled image." />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,0,0,6">
      <TextBlock Grid.Column="0" Text="Background:" VerticalAlignment="Center" Margin="0,0,4,0" />
      <ComboBox Grid.Column="1" x:Name="BackgroundCombo" SelectedIndex="0" Width="120">
        <ComboBoxItem Content="Auto" />
        <ComboBoxItem Content="White" />
        <ComboBoxItem Content="Black" />
      </ComboBox>
      <Button Grid.Column="3" Content="🚀 Run" Click="OnRunClick" FontWeight="Bold" />
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="*,8,*">
      <Border Grid.Column="0" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Text="Source scan (with detected piece outlines)"
                     Margin="8,6" FontWeight="SemiBold" />
          <Image Grid.Row="1" x:Name="SourcePreview" Stretch="Uniform" Margin="6" />
        </Grid>
      </Border>

      <Border Grid.Column="2" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Text="Assembled output" Margin="8,6" FontWeight="SemiBold" />
          <Image Grid.Row="1" x:Name="OutputPreview" Stretch="Uniform" Margin="6" />
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
      <Button Grid.Column="0" Content="💾 Save as…" Click="OnSaveAsClick" FontWeight="Bold" />
      <Button Grid.Column="2" Content="🚪 Close" Click="OnCloseClick" IsCancel="True" />
    </Grid>

    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
      <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" Opacity="0.75" />
      <ProgressBar Grid.Column="1" x:Name="ProgressBar" Width="220" Height="14"
                   Minimum="0" Maximum="100" Value="0" />
    </Grid>
  </Grid>
</Window>
