<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="620"
        x:Class="Hawkynt.PhotoManager.UI.Views.VideoExtractWindow"
        Width="780" Height="620"
        MinWidth="640" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Title="Video to frames">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="12">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
      <TextBlock Text="🎬 Extract frames from video" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Opacity="0.75" TextWrapping="Wrap"
                 Text="Pick a video file (sweep / pan / orbit) and we'll crack it into JPEG frames. Send the frames straight to the panorama stitcher to glue them back together." />
    </StackPanel>

    <Border Grid.Row="1" x:Name="MissingFfmpegBanner"
            Background="#FFF3CD" BorderBrush="#FFCD60" BorderThickness="1"
            CornerRadius="4" Padding="10" Margin="0,0,0,8" IsVisible="False">
      <StackPanel Spacing="3">
        <TextBlock FontWeight="SemiBold" Text="⚠ ffmpeg is not installed" />
        <TextBlock Opacity="0.85" TextWrapping="Wrap"
                   Text="Install ffmpeg and reopen this window. The Extract button is disabled until ffmpeg is on PATH." />
        <TextBlock FontFamily="Consolas" FontSize="12" Opacity="0.85"
                   Text="Windows:  winget install ffmpeg   (or: choco install ffmpeg)" />
        <TextBlock FontFamily="Consolas" FontSize="12" Opacity="0.85"
                   Text="macOS:    brew install ffmpeg" />
        <TextBlock FontFamily="Consolas" FontSize="12" Opacity="0.85"
                   Text="Linux:    apt install ffmpeg     (or: dnf install ffmpeg)" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="120,*,Auto" Margin="0,0,0,6">
      <TextBlock Grid.Column="0" Text="Video file:" VerticalAlignment="Center" />
      <TextBox Grid.Column="1" x:Name="VideoPathBox" Watermark="Path to .mp4 / .mov / .mkv / ..." TextChanged="OnVideoPathChanged" />
      <Button Grid.Column="2" Content="Browse..." Margin="6,0,0,0" Click="OnBrowseVideoClick" />
    </Grid>

    <Grid Grid.Row="3" ColumnDefinitions="120,*,Auto" Margin="0,0,0,6">
      <TextBlock Grid.Column="0" Text="Output folder:" VerticalAlignment="Center" />
      <TextBox Grid.Column="1" x:Name="OutputPathBox" Watermark="Defaults to {video-stem}-frames/ next to the video" />
      <Button Grid.Column="2" Content="Browse..." Margin="6,0,0,0" Click="OnBrowseOutputClick" />
    </Grid>

    <Grid Grid.Row="4" ColumnDefinitions="120,*,Auto" Margin="0,4,0,2">
      <TextBlock Grid.Column="0" Text="Frames / sec:" VerticalAlignment="Center" />
      <Slider Grid.Column="1" x:Name="FpsSlider" Minimum="0.1" Maximum="30" Value="2"
              TickFrequency="0.1" IsSnapToTickEnabled="False" />
      <TextBlock Grid.Column="2" x:Name="FpsLabel" Text="2.0 fps" Width="80" VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="5" ColumnDefinitions="120,*,Auto" Margin="0,2,0,2">
      <TextBlock Grid.Column="0" Text="Max long edge:" VerticalAlignment="Center"
                 ToolTip.Tip="Cap the longer side of each frame (px). Keeps disk + CPU sane on 4K source." />
      <ComboBox Grid.Column="1" x:Name="MaxEdgeCombo" SelectedIndex="2">
        <ComboBoxItem Content="off (native)" Tag="0" />
        <ComboBoxItem Content="1024 px" Tag="1024" />
        <ComboBoxItem Content="2048 px" Tag="2048" />
        <ComboBoxItem Content="4096 px" Tag="4096" />
        <ComboBoxItem Content="unlimited" Tag="0" />
      </ComboBox>
    </Grid>

    <Grid Grid.Row="6" ColumnDefinitions="120,*,Auto,120,*,Auto" Margin="0,2,0,2">
      <TextBlock Grid.Column="0" Text="JPEG quality:" VerticalAlignment="Center"
                 ToolTip.Tip="ffmpeg -q:v scale (1-8). 1 = highest, 8 = small files." />
      <Slider Grid.Column="1" x:Name="JpegQualitySlider" Minimum="1" Maximum="8" Value="2"
              TickFrequency="1" IsSnapToTickEnabled="True" />
      <TextBlock Grid.Column="2" x:Name="JpegQualityLabel" Text="2" Width="30" VerticalAlignment="Center" />
      <TextBlock Grid.Column="3" Text="Clip:" VerticalAlignment="Center" />
      <Grid Grid.Column="4" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto,*">
        <TextBox Grid.Column="0" x:Name="StartTimeBox" Watermark="start (hh:mm:ss)" />
        <TextBlock Grid.Column="1" Text=" → " VerticalAlignment="Center" />
        <TextBox Grid.Column="2" x:Name="EndTimeBox" Watermark="end (hh:mm:ss)" />
      </Grid>
    </Grid>

    <Border Grid.Row="7" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Margin="0,8,0,0">
      <ScrollViewer>
        <ItemsControl x:Name="FrameLog" Padding="4" />
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="8" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
      <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" Opacity="0.75" />
      <ProgressBar Grid.Column="1" x:Name="ExtractProgress" Width="200" Height="14" Minimum="0" Maximum="100" />
    </Grid>

    <StackPanel Grid.Row="9" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Content="🎬 Extract" x:Name="ExtractButton" FontWeight="Bold" Click="OnExtractClick" />
      <Button Content="❌ Cancel" x:Name="CancelButton" Click="OnCancelClick" IsVisible="False" />
      <Button Content="📂 Open output folder" x:Name="OpenFolderButton" Click="OnOpenOutputClick" IsEnabled="False" />
      <Button Content="🖼 Send to Panorama stitch" x:Name="SendPanoramaButton" Click="OnSendToPanoramaClick" IsEnabled="False" />
      <Button Content="🌐 Send to 360° spherical stitch" x:Name="SendSphericalButton" Click="OnSendToSphericalClick" IsEnabled="False" />
      <Button Content="Close" Click="OnCloseClick" IsCancel="True" />
    </StackPanel>
  </Grid>
</Window>
