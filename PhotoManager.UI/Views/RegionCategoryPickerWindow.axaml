<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="220"
        x:Class="PhotoManager.UI.Views.RegionCategoryPickerWindow"
        Width="420" Height="240" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="What's in this box?">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="12">
    <TextBlock Grid.Row="0" Text="What's in this box?" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4" />
    <TextBlock Grid.Row="1" Opacity="0.75" TextWrapping="Wrap" Margin="0,0,0,8"
               Text="Pick a category for the region you just drew. Leave the label blank to come back and tag it later via the region thumbnail." />

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="14" Margin="0,0,0,8">
      <RadioButton x:Name="PersonRadio" GroupName="Cat" Content="Person" IsChecked="True" />
      <RadioButton x:Name="ObjectRadio" GroupName="Cat" Content="Object" />
      <RadioButton x:Name="OtherRadio"  GroupName="Cat" Content="Other" />
    </StackPanel>

    <Grid Grid.Row="3" ColumnDefinitions="80,*" Margin="0,0,0,8">
      <TextBlock Grid.Column="0" Text="Label:" VerticalAlignment="Center" />
      <TextBox Grid.Column="1" x:Name="LabelBox" Watermark="(optional) name or description" />
    </Grid>

    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button Content="❌ Cancel" Click="OnCancelClick" IsCancel="True" />
      <Button Content="✅ OK" Click="OnOkClick" IsDefault="True" FontWeight="Bold" />
    </StackPanel>
  </Grid>
</Window>
