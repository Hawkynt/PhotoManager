<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:PhotoManager.UI.Models"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="500"
        x:Class="PhotoManager.UI.Views.ModelDownloadWindow"
        Width="700" Height="560"
        WindowStartupLocation="CenterOwner"
        Title="Download detection models">
  <Grid RowDefinitions="Auto,*,Auto" Margin="12">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="Detection models" FontSize="16" FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1" x:Name="DownloadAllButton" Content="⬇️ Download all missing"
                Click="OnDownloadAllClick"
                ToolTip.Tip="Sequentially download every model that isn't already installed. Already-installed models are skipped." />
      </Grid>
      <TextBlock Opacity="0.75" TextWrapping="Wrap"
                 Text="Models power object detection, face detection / clustering, AI denoise / upscale / colorize, subject masking, auto-keyword tagging. Rows tinted green are already on disk; click Re-download to refresh them or Install from file… to point at a manual copy." />
    </StackPanel>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <ItemsControl x:Name="EntriesList">
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="models:ModelCatalogEntry">
          <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                  Background="{CompiledBinding RowBackground}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="1">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="{CompiledBinding DisplayName}" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="{CompiledBinding StatusBadge}" FontSize="11" Opacity="0.85"
                             VerticalAlignment="Center" Margin="6,0,0,0" />
                </Grid>
                <TextBlock Text="{CompiledBinding Description}" TextWrapping="Wrap" Opacity="0.8" FontSize="12" />
                <TextBlock Text="{CompiledBinding SizeText}" Opacity="0.6" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Content="{CompiledBinding DownloadButtonText}"
                        IsEnabled="{CompiledBinding CanDownload}"
                        Click="OnDownloadClick"
                        Tag="{CompiledBinding Model.Name}" />
                <Button Content="📁 Install from file…"
                        Click="OnInstallFromFileClick"
                        Tag="{CompiledBinding Model.Name}"
                        ToolTip.Tip="Point at a locally-downloaded ONNX (useful when the download URL is blocked)." />
              </StackPanel>
              <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                         Margin="0,4,0,0"
                         Text="{CompiledBinding StatusText}"
                         Opacity="0.7" FontSize="11"
                         TextTrimming="CharacterEllipsis" />
              <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                           Margin="0,6,0,0"
                           Height="6"
                           Minimum="0" Maximum="1"
                           Value="{CompiledBinding DownloadFraction}"
                           IsVisible="{CompiledBinding IsDownloading}" />
              <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                         Margin="0,4,0,0"
                         Text="{CompiledBinding ProgressDetail}"
                         Opacity="0.7" FontSize="11" FontFamily="Consolas"
                         IsVisible="{CompiledBinding IsDownloading}" />
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,10,0,0">
      <Button Content="📂 Open models folder" Click="OnOpenFolderClick" />
      <Button Content="🚪 Close" Click="OnCloseClick" IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
