<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="PhotoManager.UI.Views.PersonTimelineWindow"
        Width="900" Height="600"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Title="Person timeline">
  <Grid RowDefinitions="Auto,*,Auto" Margin="12">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
      <TextBlock Text="Person timeline" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Opacity="0.75" TextWrapping="Wrap"
                 Text="For each detected person, see when they first and last appeared in your library and how many photos per year. Select a person on the left; click a year bar to filter." />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="200,4,*">
      <!-- Left sidebar: person list -->
      <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Text="Persons" Margin="8,6,8,4" FontWeight="SemiBold" />
          <ListBox Grid.Row="1" x:Name="PersonListBox" Padding="4"
                   SelectionChanged="OnPersonSelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Background="Transparent" />

      <!-- Right content: timeline chart + summary -->
      <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,Auto,*">
          <TextBlock Grid.Row="0" x:Name="PersonHeader" Margin="8,6,8,2"
                     FontSize="14" FontWeight="SemiBold" Text="(select a person)" />
          <TextBlock Grid.Row="1" x:Name="PersonSummary" Margin="8,0,8,6"
                     FontSize="12" Opacity="0.7" />

          <!-- Vertical bar chart — one column per year, built dynamically in
               code-behind because the number of bars varies per person. -->
          <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                        Margin="8,0,8,8">
            <StackPanel x:Name="ChartPanel" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Bottom" MinHeight="200" />
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
      <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" Opacity="0.75" />
      <Button Grid.Column="1" Content="🚪 Close" Width="100" Click="OnCloseClick" />
    </Grid>
  </Grid>
</Window>
