<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:PhotoManager.UI.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="PhotoManager.UI.Views.MemoriesWindow"
        Width="900" Height="600"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Title="Memories">
  <Grid RowDefinitions="Auto,*,Auto" Margin="12">
    <TabControl Grid.Row="1" x:Name="MemoriesTabs">
      <TabItem Header="On this day">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" x:Name="OnThisDayHeader" Margin="4,4,4,8" Opacity="0.7" />
          <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="OnThisDayList">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:MemoryRowViewModel">
                  <Border Width="200" Margin="4" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4"
                          DoubleTapped="OnTileDoubleTapped">
                    <StackPanel>
                      <Border Height="140" Background="{DynamicResource ThumbBackgroundBrush}">
                        <Image Source="{CompiledBinding Thumbnail}" Stretch="Uniform" />
                      </Border>
                      <StackPanel Margin="6" Spacing="2">
                        <TextBlock Text="{CompiledBinding FileName}" FontWeight="SemiBold" FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{CompiledBinding FileName}" />
                        <TextBlock Text="{CompiledBinding DateText}" FontSize="11" Opacity="0.75" />
                        <TextBlock Text="{CompiledBinding LocationText}" FontSize="11" Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>
      <TabItem Header="On this trip">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" x:Name="OnThisTripHeader" Margin="4,4,4,8" Opacity="0.7" TextWrapping="Wrap" />
          <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="OnThisTripList">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:MemoryRowViewModel">
                  <Border Width="200" Margin="4" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4"
                          DoubleTapped="OnTileDoubleTapped">
                    <StackPanel>
                      <Border Height="140" Background="{DynamicResource ThumbBackgroundBrush}">
                        <Image Source="{CompiledBinding Thumbnail}" Stretch="Uniform" />
                      </Border>
                      <StackPanel Margin="6" Spacing="2">
                        <TextBlock Text="{CompiledBinding FileName}" FontWeight="SemiBold" FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{CompiledBinding FileName}" />
                        <TextBlock Text="{CompiledBinding DateText}" FontSize="11" Opacity="0.75" />
                        <TextBlock Text="{CompiledBinding LocationText}" FontSize="11" Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>
    </TabControl>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,8,0,0">
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,8,0" />
      <Button Content="🚪 Close" Width="100" Click="OnCloseClick" />
    </StackPanel>
  </Grid>
</Window>
