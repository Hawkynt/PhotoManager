<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="240"
        x:Class="Hawkynt.PhotoManager.UI.Views.AboutWindow"
        Width="420" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="About Photo Manager">
  <Grid RowDefinitions="*,Auto" Margin="16">
    <StackPanel Grid.Row="0" Spacing="6">
      <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" />
      <TextBlock x:Name="VersionText" />
      <TextBlock x:Name="CopyrightText" Margin="0,8,0,0" />
      <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Margin="0,8,0,0" />
    </StackPanel>

    <Button Grid.Row="1" Content="✅ OK" Width="80" HorizontalAlignment="Right" Click="OnOkClick" />
  </Grid>
</Window>
