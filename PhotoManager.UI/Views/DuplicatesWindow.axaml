<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:PhotoManager.UI.Models"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="760"
        x:Class="PhotoManager.UI.Views.DuplicatesWindow"
        Width="1100" Height="760"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Title="Find duplicates">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="12">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
      <TextBlock Text="Find duplicates (perceptual hash)" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Opacity="0.75" TextWrapping="Wrap"
                 Text="Hashes every supported image into a 64-bit pHash, then groups files within a Hamming threshold. Re-encodes and tiny crops cluster together; unrelated photos won't. Hashes live in memory only — no database, mtime keys cached entries." />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,6">
      <TextBlock Grid.Column="0" Text="Folder:" VerticalAlignment="Center" Margin="0,0,6,0" />
      <TextBox Grid.Column="1" x:Name="FolderBox" Watermark="Path to library root" />
      <Button Grid.Column="2" Content="📂 Browse..." Margin="6,0,0,0" Click="OnBrowseClick" />
      <Button Grid.Column="3" Content="🔍 Scan" Margin="6,0,0,0" Click="OnScanClick" FontWeight="Bold" />
      <CheckBox Grid.Column="4" x:Name="RecursiveBox" Content="Recursive" IsChecked="True" Margin="12,0,0,0" VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" Margin="0,0,0,8">
      <TextBlock Grid.Column="0" Text="Threshold (bits):" VerticalAlignment="Center" Margin="0,0,6,0"
                 ToolTip.Tip="Maximum Hamming distance for two files to count as duplicates. 0 = identical hash, ~6 = visually identical, 10+ = loosely related." />
      <NumericUpDown Grid.Column="1" x:Name="ThresholdBox" Value="6" Minimum="0" Maximum="20" Width="100" />
      <Button Grid.Column="2" Content="🔄 Re-cluster" Margin="6,0,0,0" Click="OnReclusterClick"
              ToolTip.Tip="Re-bucket the already-hashed files at the new threshold without rescanning." />
    </Grid>

    <Border Grid.Row="3" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="GroupsList" Padding="6">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="models:DuplicateGroupViewModel">
              <Border Margin="4" Padding="6" BorderBrush="{DynamicResource TileBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource SubtlePanelBrush}">
                <StackPanel Spacing="6">
                  <TextBlock Text="{CompiledBinding Header}" FontWeight="SemiBold" FontSize="13" />
                  <ItemsControl ItemsSource="{CompiledBinding Members}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="models:DuplicateMemberViewModel">
                        <Border Width="200" Margin="4" BorderBrush="{DynamicResource TileBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource TileSurfaceBrush}"
                                DoubleTapped="OnMemberDoubleTapped"
                                ToolTip.Tip="{CompiledBinding FullPath}">
                          <StackPanel>
                            <Border Height="160" Background="{DynamicResource ThumbBackgroundBrush}">
                              <Image Source="{CompiledBinding Thumbnail}" Stretch="Uniform" />
                            </Border>
                            <StackPanel Margin="6" Spacing="2">
                              <TextBlock Text="{CompiledBinding FileName}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{CompiledBinding DistanceLabel}" FontSize="11" Opacity="0.7" />
                            </StackPanel>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
      <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" Opacity="0.75" />
      <Button Grid.Column="1" Content="🚪 Close" Click="OnCloseClick" IsCancel="True" />
    </Grid>
  </Grid>
</Window>
