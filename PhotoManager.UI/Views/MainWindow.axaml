<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PhotoManager.UI.Models"
        xmlns:models="using:PhotoManager.UI.Models"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="PhotoManager.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Photo Manager"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="560">
  <Window.Styles>
    <Style Selector="ListBoxItem.winner">
      <Setter Property="Background" Value="#CCF2CC" />
      <Setter Property="Foreground" Value="#054905" />
    </Style>
    <Style Selector="ListBoxItem.missing">
      <Setter Property="Background" Value="#FFD6CC" />
      <Setter Property="Foreground" Value="#7a1a0e" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto,Auto">
    <Menu Grid.Row="0">
      <MenuItem Header="_Help">
        <MenuItem Header="_About..." Click="OnAboutClick" />
      </MenuItem>
    </Menu>

    <Grid Grid.Row="1" ColumnDefinitions="280,4,*,4,360">
      <!-- Left pane: source tree -->
      <Border Grid.Column="0" Margin="8,8,0,0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Text="Source Paths" Margin="8,6,8,2" FontWeight="SemiBold" />
          <TreeView Grid.Row="1" x:Name="SourceTree" SelectionMode="Single" Padding="4">
            <TreeView.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Add Path..." Click="OnAddPathClick" />
                <MenuItem Header="Remove Path" Click="OnRemovePathClick" />
                <Separator />
                <MenuItem Header="Toggle Recursive" Click="OnToggleRecursiveClick" />
              </ContextMenu>
            </TreeView.ContextMenu>
            <TreeView.ItemTemplate>
              <TreeDataTemplate DataType="models:SourceTreeNode" ItemsSource="{CompiledBinding Children}">
                <StackPanel Orientation="Horizontal" Spacing="4" ToolTip.Tip="{CompiledBinding FullPathTooltip}">
                  <CheckBox IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}" />
                  <TextBlock Text="{CompiledBinding DisplayName}" VerticalAlignment="Center" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Background="Transparent" />

      <!-- Center pane: settings + file grid -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*" Margin="0,8,0,0">
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,6">
          <Grid ColumnDefinitions="120,*,Auto">
            <TextBlock Grid.Column="0" Text="Output:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding DestinationDirectory, Mode=TwoWay}" Watermark="(organize in-place if empty)" />
            <Button Grid.Column="2" Content="Select Output..." Margin="6,0,0,0" Click="OnBrowseDestinationClick" />
          </Grid>
          <Grid ColumnDefinitions="120,Auto,Auto,*">
            <TextBlock Grid.Column="0" Text="Duplicates:" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" x:Name="DuplicateHandlingCombo" Width="180"
                      SelectedItem="{Binding DuplicateHandling, Mode=TwoWay}" />
            <CheckBox Grid.Column="2" Content="Copy (don't move)" Margin="16,0,0,0"
                      IsChecked="{Binding PreserveOriginals, Mode=TwoWay}" />
          </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="FilesGrid"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="OnFileSelectionChanged">
          <DataGrid.Columns>
            <DataGridTextColumn Header="File Name" Binding="{CompiledBinding FileName, DataType=models:FileItemModel}" Width="*" />
            <DataGridTextColumn Header="Target Location" Binding="{CompiledBinding TargetLocation, DataType=models:FileItemModel}" Width="2*" />
            <DataGridTextColumn Header="Source Path" Binding="{CompiledBinding SourcePath, DataType=models:FileItemModel}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>

      <GridSplitter Grid.Column="3" Background="Transparent" />

      <!-- Right pane: preview (top) + metadata (bottom) -->
      <Grid Grid.Column="4" RowDefinitions="*,4,*" Margin="0,8,8,0">
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
          <Image x:Name="PreviewImage"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 DoubleTapped="OnPreviewDoubleTapped" />
        </Border>

        <GridSplitter Grid.Row="1" Background="Transparent" ResizeDirection="Rows" />

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" Text="Metadata" Margin="8,6,8,2" FontWeight="SemiBold" />
            <ListBox Grid.Row="1" x:Name="MetadataList" Padding="0" BorderThickness="0">
              <ListBox.ItemContainerTheme>
                <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                  <Setter Property="Padding" Value="8,3" />
                </ControlTheme>
              </ListBox.ItemContainerTheme>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="models:MetadataRow">
                  <Grid ColumnDefinitions="140,*">
                    <TextBlock Grid.Column="0" Text="{CompiledBinding Name}" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{CompiledBinding Value}" TextWrapping="Wrap" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,8,8,0" Spacing="6">
      <Button Content="Scan Files"       Click="OnScanClick"         IsEnabled="{Binding !IsProcessing}" />
      <Button Content="Run"  FontWeight="Bold" Click="OnRunClick"    IsEnabled="{Binding !IsProcessing}" />
      <Button Content="Run on Directory" Click="OnRunDirectoryClick" IsEnabled="{Binding !IsProcessing}" />
      <Button Content="Cancel"           Click="OnCancelClick"       IsEnabled="{Binding IsProcessing}" />
      <CheckBox Content="Recursive (Run on Directory)" Margin="24,0,0,0"
                IsChecked="{Binding Recursive, Mode=TwoWay}" />
    </StackPanel>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="8,6,8,8">
      <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center" />
      <ProgressBar Grid.Column="1" Width="240" Height="16"
                   Minimum="0" Maximum="100"
                   Value="{Binding ProgressValue}" />
    </Grid>
  </Grid>
</Window>
