<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Hawkynt.PhotoManager.UI.Models"
        xmlns:models="using:Hawkynt.PhotoManager.UI.Models"
        xmlns:mapsui="using:Mapsui.UI.Avalonia"
        xmlns:controls="using:Hawkynt.PhotoManager.UI.Controls"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="Hawkynt.PhotoManager.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Photo Manager"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="560">
  <Window.Styles>
    <!-- Dirty-edit highlight: the DirtyTracker toggles ".dirty" on any
         input whose value has changed since the last clean snapshot. -->
    <Style Selector="TextBox.dirty">
      <Setter Property="Background" Value="#DCE8F5" />
    </Style>
    <Style Selector="ComboBox.dirty">
      <Setter Property="Background" Value="#DCE8F5" />
    </Style>
    <Style Selector="CheckBox.dirty">
      <Setter Property="Background" Value="#DCE8F5" />
    </Style>
    <Style Selector="ToggleButton.dirty">
      <Setter Property="Background" Value="#DCE8F5" />
    </Style>

    <!-- Star rating chips: gold star always; checked = filled gold pill so
         a glance reveals the rating. Reject chip flips between red outline
         and red fill. -->
    <Style Selector="ToggleButton.star">
      <Setter Property="Foreground" Value="#BFBFBF" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ToggleButton.star:checked">
      <Setter Property="Background" Value="#FFE08A" />
      <Setter Property="Foreground" Value="#B8860B" />
    </Style>
    <!-- Defeat the Fluent default that re-tints background on hover/press
         while checked, which was washing out the gold fill. -->
    <Style Selector="ToggleButton.star:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FFE08A" />
      <Setter Property="Foreground" Value="#B8860B" />
    </Style>

    <Style Selector="ToggleButton.reject">
      <Setter Property="Foreground" Value="#C0392B" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ToggleButton.reject:checked">
      <Setter Property="Background" Value="#C0392B" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ToggleButton.reject:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#C0392B" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Color-label chips: when checked, fill with the label color, white
         text — same look as Adobe DAMs for instant recognition. -->
    <Style Selector="ToggleButton.label-red">
      <Setter Property="Foreground" Value="#C0392B" />
    </Style>
    <Style Selector="ToggleButton.label-red:checked">
      <Setter Property="Background" Value="#C0392B" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ToggleButton.label-red:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#C0392B" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ToggleButton.label-yellow">
      <Setter Property="Foreground" Value="#B7950B" />
    </Style>
    <Style Selector="ToggleButton.label-yellow:checked">
      <Setter Property="Background" Value="#F1C40F" />
      <Setter Property="Foreground" Value="#5B4500" />
    </Style>
    <Style Selector="ToggleButton.label-yellow:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#F1C40F" />
      <Setter Property="Foreground" Value="#5B4500" />
    </Style>

    <Style Selector="ToggleButton.label-green">
      <Setter Property="Foreground" Value="#1E8449" />
    </Style>
    <Style Selector="ToggleButton.label-green:checked">
      <Setter Property="Background" Value="#1E8449" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ToggleButton.label-green:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#1E8449" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ToggleButton.label-blue">
      <Setter Property="Foreground" Value="#2471A3" />
    </Style>
    <Style Selector="ToggleButton.label-blue:checked">
      <Setter Property="Background" Value="#2471A3" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ToggleButton.label-blue:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#2471A3" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ToggleButton.label-purple">
      <Setter Property="Foreground" Value="#7D3C98" />
    </Style>
    <Style Selector="ToggleButton.label-purple:checked">
      <Setter Property="Background" Value="#7D3C98" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ToggleButton.label-purple:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#7D3C98" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="DatePicker.dirty">
      <Setter Property="Background" Value="#DCE8F5" />
    </Style>
    <Style Selector="TimePicker.dirty">
      <Setter Property="Background" Value="#DCE8F5" />
    </Style>
  </Window.Styles>
  <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="📁 _Add folder..." Click="OnAddPathClick" InputGesture="Ctrl+O" />
        <MenuItem Header="📂 Select _output..." Click="OnBrowseDestinationClick" />
        <Separator />
        <MenuItem Header="📁 Recent _sources" x:Name="RecentSourcesMenu">
          <MenuItem Header="(none)" IsEnabled="False" />
        </MenuItem>
        <MenuItem Header="📂 Recent _output folders" x:Name="RecentOutputsMenu">
          <MenuItem Header="(none)" IsEnabled="False" />
        </MenuItem>
        <Separator />
        <MenuItem Header="⚙️ _Settings…" Click="OnOpenSettingsClick" InputGesture="Ctrl+," />
        <Separator />
        <MenuItem Header="🚪 E_xit" Click="OnExitClick" InputGesture="Alt+F4" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="🎨 _Theme">
          <MenuItem Header="☀ _Light" ToggleType="Radio" GroupName="theme"
                    x:Name="ThemeLightItem" Click="OnThemeLightClick" />
          <MenuItem Header="🌙 _Dark" ToggleType="Radio" GroupName="theme"
                    x:Name="ThemeDarkItem" Click="OnThemeDarkClick" />
          <MenuItem Header="🖥 _System default" ToggleType="Radio" GroupName="theme"
                    x:Name="ThemeSystemItem" Click="OnThemeSystemClick" />
        </MenuItem>
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="🔍 _Search library..." Click="OnOpenSearchClick" InputGesture="Ctrl+F" />
        <MenuItem Header="🔁 Find _duplicates..." Click="OnOpenDuplicatesClick"
                  ToolTip.Tip="Scan a folder for visually similar photos via 64-bit perceptual hash. Hashes live in memory only; no DB on disk." />
        <MenuItem Header="📊 Analyse _quality flags..." Click="OnOpenQualityScanClick"
                  ToolTip.Tip="Run sharpness (Laplacian variance) + exposure (histogram clipping) heuristics over a folder; tag blurry / over-/under-exposed photos with qa: keywords." />
        <MenuItem Header="🧠 Smart _albums..." Click="OnOpenSmartAlbumsClick"
                  ToolTip.Tip="Compose multi-clause smart albums (rating ≥ 3 AND keyword 'vacation' AND GPS within box) and load them into the search filter." />
        <MenuItem Header="🌳 Keyword _tree..." Click="OnOpenKeywordTreeClick"
                  ToolTip.Tip="Manage a hierarchical keyword tree (Travel > Italy > Rome). Selecting a leaf writes leaf + ancestors as flat dc:subject keywords." />
        <MenuItem Header="📅 Calendar _view..." Click="OnOpenCalendarClick"
                  ToolTip.Tip="Photos grouped by capture date in a month-grid; click a day to drill into the photos taken that day." />
        <MenuItem Header="🗂 Detect _bursts..." Click="OnOpenBurstStacksClick"
                  ToolTip.Tip="Cluster photos taken in rapid succession into burst groups; tag each group with a pm:burstId keyword." />
        <MenuItem Header="✏️ Batch _rename..." Click="OnOpenBatchRenameClick"
                  ToolTip.Tip="Rename every selected file using a metadata-aware template like {date:yyyy-MM-dd}_{city}_{name}." />
        <MenuItem Header="🕒 Batch date _shift..." Click="OnOpenBatchDateShiftClick"
                  ToolTip.Tip="Shift the EXIF capture timestamp on every selected JPEG by a fixed offset. Use when the camera clock was wrong (timezone, DST, drift)." />
        <Separator />
        <MenuItem Header="📍 Geotag from _GPX..." Click="OnOpenGpxClick" />
        <MenuItem Header="🌍 _World map..." Click="OnOpenWorldMapClick" />
        <MenuItem Header="🗺️ Map _bookmarks..." Click="OnOpenMapBookmarksClick"
                  ToolTip.Tip="Save named places (lat/lon + city/country fields) and apply them to a selection in one click." />
        <MenuItem Header="🌐 Reverse-geocode _selection..." Click="OnReverseGeocodeSelectionClick"
                  ToolTip.Tip="Resolve city/country/state for every selected photo's GPS coordinate in one batch." />
        <MenuItem Header="📤 Export _KML..." Click="OnExportKmlClick"
                  ToolTip.Tip="Save every geotagged photo's coordinates to a single .kml file (Google Earth / GPX viewers)." />
        <MenuItem Header="🎯 Apply _geofences to selection..." Click="OnOpenGeofenceBatchClick"
                  ToolTip.Tip="For every selected geotagged photo, apply the place fields of any saved bookmark whose radius contains the photo's GPS." />
        <MenuItem Header="👤 _Face gallery..." Click="OnOpenFaceGalleryClick" />
        <MenuItem Header="👤 Person _timeline..." Click="OnOpenPersonTimelineClick"
                  ToolTip.Tip="For each detected person, see when they first and last appeared and how many photos per year." />
        <MenuItem Header="🎨 _Develop image..." Click="OnOpenDevelopClick" InputGesture="Ctrl+E"
                  IsEnabled="{Binding HasSelectedFile}" />
        <MenuItem Header="🪄 _Restore old photo..." Click="OnOpenRestoreClick"
                  IsEnabled="{Binding HasSelectedFile}"
                  ToolTip.Tip="Auto-restore old / damaged photos: face restoration (GFPGAN), denoise, recolour, upscale. Pick a preset for inexperienced one-click results." />
        <Separator />
        <MenuItem Header="🌅 _HDR merge..." Click="OnOpenHdrMergeClick"
                  ToolTip.Tip="Merge a bracket of differently-exposed photos into a single HDR image via Debevec response-curve recovery + Reinhard / Drago tone mapping." />
        <MenuItem Header="🖼 Panorama _stitch..." Click="OnOpenPanoramaStitchClick"
                  ToolTip.Tip="Stitch overlapping photos into a panorama. Tripod mode = hand-rolled cylindrical projection; hand-held mode = OpenCV high-level Stitcher (gigapixel-friendly); spherical mode = full 360° equirectangular." />
        <MenuItem Header="🧩 Stitch torn _pieces..." Click="OnOpenPieceStitchClick"
                  ToolTip.Tip="Reassemble a single scan that contains several ripped pieces of one photograph. Detects each piece against the uniform scanner background, matches torn edges, and emits a composited result." />
        <MenuItem Header="🎬 _Video to frames..." Click="OnOpenVideoExtractClick"
                  ToolTip.Tip="Split a video into individual JPEG frames via ffmpeg. Pipe the result straight into the panorama stitcher to build a sweep from a single take." />
        <MenuItem Header="🌐 _360° viewer..." Click="OnOpenPanoramaViewerClick"
                  IsEnabled="{Binding HasSelectedFile}"
                  ToolTip.Tip="Open the selected equirectangular spherical photo as a navigable 360° view (drag to look around, scroll to zoom)." />
        <Separator />
        <MenuItem Header="✨ _Memories..." Click="OnOpenMemoriesClick"
                  ToolTip.Tip="On this day / on this trip — re-discover photos around today and around the selected anchor" />
        <MenuItem Header="📌 Quick _collection">
          <MenuItem Header="_Clear" Click="OnQuickCollectionClearClick" />
          <Separator />
          <MenuItem Header="Select in grid (for Batch _rename / Properties)" Click="OnQuickCollectionSelectInGridClick" />
          <MenuItem Header="Open in Develop _apply-to-selection..." Click="OnQuickCollectionDevelopClick" />
        </MenuItem>
        <MenuItem Header="🏷️ _Auto-keyword scan..." Click="OnOpenAutoKeywordScanClick"
                  ToolTip.Tip="Use a CLIP-style image embedding model to tag photos with the closest matches from a built-in vocabulary. Writes dc:subject keywords." />
        <Separator />
        <MenuItem Header="🤖 _Download detection models..." Click="OnOpenModelsDialogClick" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="ℹ️ _About..." Click="OnAboutClick" />
      </MenuItem>
    </Menu>

    <Grid Grid.Row="1" ColumnDefinitions="280,4,*,4,360">
      <!-- Left pane: source tree -->
      <Border Grid.Column="0" Margin="8,8,0,0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,Auto,*">
          <!-- Toggle which directory tree the grid pulls from. "Sources" is
               the default scan; "Target" walks the destination directory
               recursively so the user can keep editing metadata after
               files have been organised. -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="8,6,8,2">
            <RadioButton GroupName="BrowseMode" Content="Sources" IsChecked="True"
                         Tag="Sources" Checked="OnBrowseModeChanged" />
            <RadioButton GroupName="BrowseMode" Content="Target"
                         Tag="Target" Checked="OnBrowseModeChanged"
                         ToolTip.Tip="Walk the configured destination directory recursively" />
          </StackPanel>
          <TextBlock Grid.Row="1" Text="Source Paths" Margin="8,2,8,2" FontWeight="SemiBold"
                     IsVisible="{Binding IsSourceMode}" />
          <StackPanel Grid.Row="1" Margin="8,2,8,2" Spacing="2"
                      IsVisible="{Binding IsTargetMode}">
            <TextBlock Text="Target Directory" FontWeight="SemiBold" />
            <TextBlock Text="{Binding DestinationDirectory}" FontFamily="Consolas" FontSize="11"
                       Opacity="0.75" TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding DestinationDirectory}" />
            <TextBlock Text="(walking recursively)" Opacity="0.55" FontStyle="Italic" FontSize="11" />
          </StackPanel>
          <TreeView Grid.Row="2" x:Name="SourceTree" SelectionMode="Single" Padding="4"
                    IsVisible="{Binding IsSourceMode}"
                    DragDrop.AllowDrop="True">
            <TreeView.ContextMenu>
              <ContextMenu>
                <MenuItem Header="📁 Add Path..." Click="OnAddPathClick" />
                <MenuItem Header="❌ Remove Path" Click="OnRemovePathClick" />
                <Separator />
                <MenuItem Header="🔁 Toggle Recursive" Click="OnToggleRecursiveClick" />
              </ContextMenu>
            </TreeView.ContextMenu>
            <TreeView.ItemTemplate>
              <TreeDataTemplate DataType="models:SourceTreeNode" ItemsSource="{CompiledBinding Children}">
                <StackPanel Orientation="Horizontal" Spacing="4" ToolTip.Tip="{CompiledBinding FullPathTooltip}">
                  <CheckBox IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}" />
                  <TextBlock Text="{CompiledBinding DisplayName}" VerticalAlignment="Center" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Background="Transparent" />

      <!-- Center pane: settings (top) + preview (middle) + file grid (bottom),
           with a sizable splitter between preview and grid so the user can
           spend most vertical space on whichever they care about. -->
      <Grid Grid.Column="2" RowDefinitions="Auto,2*,4,Auto,Auto,Auto,*" Margin="0,8,0,0">
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,6">
          <Grid ColumnDefinitions="120,*,Auto">
            <TextBlock Grid.Column="0" Text="Output:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding DestinationDirectory, Mode=TwoWay}" Watermark="(organize in-place if empty)" />
            <Button Grid.Column="2" Content="📂 Select Output..." Margin="6,0,0,0" Click="OnBrowseDestinationClick" />
          </Grid>
          <Grid ColumnDefinitions="120,Auto,Auto,*">
            <TextBlock Grid.Column="0" Text="Duplicates:" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" x:Name="DuplicateHandlingCombo" Width="180"
                      SelectedItem="{Binding DuplicateHandling, Mode=TwoWay}" />
            <CheckBox Grid.Column="2" Content="Copy (don't move)" Margin="16,0,0,0"
                      IsChecked="{Binding PreserveOriginals, Mode=TwoWay}" />
          </Grid>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource ThumbBackgroundBrush}">
          <!-- Image + Canvas share the same Grid cell with explicit
               Stretch alignment — TryGetImageRenderBounds assumes they have
               matching layout bounds so the overlay rectangles track the
               rendered bitmap exactly. -->
          <Grid>
            <Image x:Name="PreviewImage"
                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   Stretch="Uniform"
                   StretchDirection="DownOnly"
                   DoubleTapped="OnPreviewDoubleTapped" />
            <!-- Background="Transparent" is essential: without a brush the
                 Canvas is only hittable on its rectangle children, so pointer
                 presses on empty image area fall through to the Image (which
                 doesn't handle them) and Draw-Box never starts. -->
            <Canvas x:Name="RegionOverlay"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="Transparent" />
          </Grid>
        </Border>

        <GridSplitter Grid.Row="2" ResizeDirection="Rows" Background="Transparent"
                      HorizontalAlignment="Stretch" />

        <!-- Live filter over the grid. Space-separates into AND tokens; each
             token CONTAINS-matches against the file's index string (built in
             the background after scan). -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" Margin="0,4,0,2">
          <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="2,0,6,0" FontSize="14" />
          <TextBox Grid.Column="1" x:Name="SearchBox" TextChanged="OnSearchTextChanged"
                   Watermark="Filter: filename, folder, keyword, person, location… (space = AND)"
                   ToolTip.Tip="Each space-separated token must match somewhere. 'alice berlin' finds photos tagged Alice in Berlin." />
          <Button Grid.Column="2" Content="✕" Width="28" Margin="4,0,0,0" Click="OnClearSearchClick"
                  ToolTip.Tip="Clear filter" />
          <ComboBox Grid.Column="3" x:Name="SavedSearchesCombo" Width="180" Margin="6,0,0,0"
                    PlaceholderText="(saved searches)"
                    SelectionChanged="OnSavedSearchSelected"
                    ToolTip.Tip="Pick a previously saved filter to re-apply" />
          <Button Grid.Column="4" Content="💾 Save…" Margin="4,0,0,0" Click="OnSaveSearchClick"
                  ToolTip.Tip="Bookmark the current text + chip filter under a name" />
          <ToggleButton Grid.Column="5" x:Name="QuickCollectionToggle" Content="📌 Quick"
                        Margin="6,0,0,0" Padding="8,2"
                        Click="OnQuickCollectionToggleClick"
                        ToolTip.Tip="Show only files in the quick collection (toggle membership with B on a row)" />
          <ToggleButton Grid.Column="6" x:Name="TimelineStripToggle" Content="📅"
                        Margin="6,0,0,0" Padding="8,2"
                        Click="OnTimelineStripToggleClick"
                        ToolTip.Tip="Show / hide the timeline scrubber strip above the grid" />
        </Grid>

        <controls:TimelineScrubber Grid.Row="5" x:Name="TimelineStrip"
                                   IsVisible="{Binding TimelineExpanded}"
                                   Margin="0,2,0,4" Height="74" />

        <!-- Rating + color chips. Toggling them AND-combines with the search
             text; e.g. ★≥3 + Red shows only 3-star+ red-labelled files. -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="3" Margin="0,0,0,4">
          <TextBlock Text="★" VerticalAlignment="Center" Margin="2,0,4,0" FontSize="13" />
          <ToggleButton x:Name="StarFilter1" Content="≥1" Padding="6,2" FontSize="11" Click="OnStarFilterClick" Tag="1" />
          <ToggleButton x:Name="StarFilter2" Content="≥2" Padding="6,2" FontSize="11" Click="OnStarFilterClick" Tag="2" />
          <ToggleButton x:Name="StarFilter3" Content="≥3" Padding="6,2" FontSize="11" Click="OnStarFilterClick" Tag="3" />
          <ToggleButton x:Name="StarFilter4" Content="≥4" Padding="6,2" FontSize="11" Click="OnStarFilterClick" Tag="4" />
          <ToggleButton x:Name="StarFilter5" Content="5"  Padding="6,2" FontSize="11" Click="OnStarFilterClick" Tag="5" />
          <Border Width="1" Background="#CCC" Margin="6,2,6,2" />
          <ToggleButton x:Name="LabelRed"    Content="Red"    Padding="6,2" FontSize="11" Click="OnLabelFilterClick" Tag="Red"    Foreground="#C0392B" FontWeight="SemiBold" />
          <ToggleButton x:Name="LabelYellow" Content="Yellow" Padding="6,2" FontSize="11" Click="OnLabelFilterClick" Tag="Yellow" Foreground="#B7950B" FontWeight="SemiBold" />
          <ToggleButton x:Name="LabelGreen"  Content="Green"  Padding="6,2" FontSize="11" Click="OnLabelFilterClick" Tag="Green"  Foreground="#1E8449" FontWeight="SemiBold" />
          <ToggleButton x:Name="LabelBlue"   Content="Blue"   Padding="6,2" FontSize="11" Click="OnLabelFilterClick" Tag="Blue"   Foreground="#2471A3" FontWeight="SemiBold" />
          <ToggleButton x:Name="LabelPurple" Content="Purple" Padding="6,2" FontSize="11" Click="OnLabelFilterClick" Tag="Purple" Foreground="#7D3C98" FontWeight="SemiBold" />
          <Border Width="1" Background="#CCC" Margin="6,2,6,2" />
          <!-- Picasa-style cull chip: cycles Show all → Hide rejects →
               Picks only → Rejects only → back. Hotkeys P/X/U on the grid
               flag the selection without leaving the keyboard. -->
          <Button x:Name="PickFilterChip" Padding="6,2" FontSize="11" Click="OnPickFilterChipClick"
                  Content="🚩 Show all"
                  ToolTip.Tip="Cull filter — click to cycle Show all → Hide rejects → Picks only → Rejects only. Grid hotkeys: P=Pick, X=Reject, U=Clear flags." />
        </StackPanel>

        <DataGrid Grid.Row="6" x:Name="FilesGrid"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  DragDrop.AllowDrop="True"
                  SelectionChanged="OnFileSelectionChanged"
                  KeyDown="OnFilesGridKeyDown">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="🎨 _Develop image..." InputGesture="Ctrl+E" Click="OnOpenDevelopClick" />
              <MenuItem Header="🪄 _Restore old photo..." Click="OnOpenRestoreClick" />
              <MenuItem Header="📋 _Properties..." Click="OnFilePropertiesClick" />
              <Separator />
              <MenuItem Header="✅ Mark as _Pick (P)" Click="OnContextMarkPickClick" />
              <MenuItem Header="❌ Mark as _Reject (X)" Click="OnContextMarkRejectClick" />
              <MenuItem Header="⚪ _Unflag (U)" Click="OnContextClearFlagClick" />
              <Separator />
              <MenuItem Header="🌐 Reverse-geocode selection..." Click="OnReverseGeocodeSelectionClick" />
              <Separator />
              <MenuItem Header="🖼️ Open in default _viewer" Click="OnOpenInViewerClick" />
              <MenuItem Header="🌐 Open in 360° v_iewer" Click="OnOpenIn360ViewerClick" />
              <MenuItem Header="📂 Show in _folder" Click="OnRevealInFolderClick" />
              <Separator />
              <MenuItem x:Name="PromoteCopyMenuItem" Header="📋 Promote copy to original" IsVisible="False" Click="OnPromoteCopyClick"
                        ToolTip.Tip="Replace the source's main XMP with this virtual copy's settings and remove the copy sidecar." />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTextColumn Header="🚩"
                                Binding="{CompiledBinding PickRejectGlyph, DataType=models:FileItemModel}"
                                Width="36"
                                CanUserSort="True"
                                CanUserResize="False" />
            <DataGridTextColumn Header="📌"
                                Binding="{CompiledBinding QuickCollectionBadge, DataType=models:FileItemModel}"
                                Width="32"
                                CanUserResize="False" CanUserSort="False" />
            <DataGridTextColumn Header="File Name" Binding="{CompiledBinding FileName, DataType=models:FileItemModel}" Width="*" />
            <DataGridTextColumn Header="Target Location" Binding="{CompiledBinding TargetLocation, DataType=models:FileItemModel}" Width="2*" />
            <DataGridTextColumn Header="Source Path" Binding="{CompiledBinding SourcePath, DataType=models:FileItemModel}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>

      <GridSplitter Grid.Column="3" Background="Transparent" />

      <!-- Right pane: metadata on top (everything editable), regions below.
           The previous split across three boxes (read-only metadata / regions /
           edit metadata) has been fused into two: "Metadata" now owns every
           file attribute including file name, capture date, GPS, keywords etc;
           "Regions" stays on its own so users can grow whichever section they
           care about right now. -->
      <Grid Grid.Column="4" Margin="0,8,8,0" RowDefinitions="2*,4,*">
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
          <Grid RowDefinitions="Auto,Auto,*">
            <TextBlock Grid.Row="0" Text="Regions" Margin="8,6,8,2" FontWeight="SemiBold" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="4,0,4,4"
                        IsEnabled="{Binding HasSelectedFile}">
              <Button Content="📦" FontSize="14" Width="34" Height="30" Padding="0" Click="OnProposeRegionsClick"
                      ToolTip.Tip="Detect Objects — run the YOLO object detector and add the matches as proposed regions to review" />
              <Button Content="👤" FontSize="14" Width="34" Height="30" Padding="0" Click="OnDetectFacesClick"
                      ToolTip.Tip="Detect Faces — run the face detector; if an ArcFace model is installed each face also gets an embedding" />
              <ToggleButton x:Name="DrawRegionToggle" Content="✏️" FontSize="14" Width="34" Height="30" Padding="0"
                            Checked="OnDrawRegionToggled" Unchecked="OnDrawRegionToggled"
                            ToolTip.Tip="Draw Rectangle — click-drag on the preview to manually add a region" />
              <TextBlock x:Name="RegionsSummary" VerticalAlignment="Center" Opacity="0.7" />
            </StackPanel>
            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsControl x:Name="RegionsList">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="models:RegionThumbnailViewModel">
                        <Border Width="180" Margin="4" Padding="0"
                                BorderBrush="{CompiledBinding CategoryColor}" BorderThickness="2" CornerRadius="4"
                                Background="{DynamicResource TileSurfaceBrush}">
                          <StackPanel>
                            <Border Height="120" Background="{DynamicResource ThumbBackgroundBrush}">
                              <Image Source="{CompiledBinding Thumbnail}" Stretch="Uniform" />
                            </Border>
                            <StackPanel Margin="6" Spacing="3">
                              <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{CompiledBinding CategoryText}" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="·" FontSize="11" Opacity="0.5" IsVisible="{CompiledBinding IsProposed}" />
                                <TextBlock Text="proposed" FontSize="11" Opacity="0.5" IsVisible="{CompiledBinding IsProposed}" />
                              </StackPanel>
                              <TextBlock Text="{CompiledBinding DisplayLabel}" FontSize="12" FontWeight="SemiBold"
                                         TextTrimming="CharacterEllipsis"
                                         ToolTip.Tip="{CompiledBinding DisplayLabel}" />
                              <StackPanel Orientation="Horizontal" Spacing="3">
                                <Button Content="Accept"  FontSize="11" Padding="6,2" Click="OnAcceptRegionClick"  Tag="{CompiledBinding Index}"
                                        IsVisible="{CompiledBinding ShowAccept}"
                                        ToolTip.Tip="Confirm this region and keep its current label" />
                                <Button Content="Dismiss" FontSize="11" Padding="6,2" Click="OnDiscardRegionClick" Tag="{CompiledBinding Index}"
                                        ToolTip.Tip="Remove the region entirely" />
                                <Button Content="Tag..."  FontSize="11" Padding="6,2" Click="OnTagRegionClick"     Tag="{CompiledBinding Index}"
                                        ToolTip.Tip="Pick or create a person to attach to this region" />
                              </StackPanel>
                            </StackPanel>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1" ResizeDirection="Rows" HorizontalAlignment="Stretch" Background="Transparent" />

        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
          <Grid RowDefinitions="Auto,Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,6,8,2">
              <TextBlock Grid.Column="0" Text="Metadata" FontWeight="SemiBold" />
              <Button Grid.Column="1" Content="📋 All properties…" Padding="6,2" FontSize="11"
                      Click="OnShowPropertiesForCurrentFileClick"
                      IsEnabled="{Binding HasSelectedFile}"
                      ToolTip.Tip="Open the full Properties dialog — edit every IPTC / XMP / EXIF tag the library supports" />
            </Grid>

            <!-- Mini-map + stacked icon buttons. The map shows camera pin (blue),
                 target pin (red) and a direction cone if the metadata provides
                 any of those. Buttons are icon-only with tooltips for space. -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="4,0,4,4" Height="180"
                  IsEnabled="{Binding HasSelectedFile}">
              <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="2">
                <mapsui:MapControl x:Name="MiniMapControl" />
              </Border>
              <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4" Margin="6,0,0,0">
                <Button Content="📍" Width="32" Height="32" Padding="0" Click="OnPickOnMapClick"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        ToolTip.Tip="Set GPS location on a map" />
                <Button Content="🎯" Width="32" Height="32" Padding="0" Click="OnPickTargetOnMapClick"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        ToolTip.Tip="Set target (subject) coordinates on a map" />
                <Button Content="📐" Width="32" Height="32" Padding="0" Click="OnTriangulateClick"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        ToolTip.Tip="Triangulate from photo — click 2-3 landmarks to compute heading, target and (optionally) camera position" />
                <Button Content="🏘" Width="32" Height="32" Padding="0" Click="OnResolveAddressClick"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        ToolTip.Tip="Retrieve location from GPS (reverse-geocode to city/state/country)" />
                <Button Content="⛰" Width="32" Height="32" Padding="0" Click="OnFillElevationClick"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        ToolTip.Tip="Retrieve height (look up altitude from GPS)" />
              </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="4" Margin="4" IsEnabled="{Binding HasSelectedFile}">
                <!-- File identity + read-only facts. Changing the Name box
                     renames the file on Save (with collision protection). -->
                <Grid ColumnDefinitions="80,*,Auto">
                  <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center"
                             ToolTip.Tip="Renames the file on disk when you click Save. Extension is locked — see the field on the right." />
                  <TextBox Grid.Column="1" x:Name="FileNameBox" />
                  <TextBox Grid.Column="2" x:Name="FileExtensionBox"
                           IsReadOnly="True" Width="56" Margin="4,0,0,0"
                           Background="#F5F5F5" Foreground="#666"
                           ToolTip.Tip="Extension is locked. Format-mismatch warnings surface in the status bar; rename in the OS file manager if you really need to change it." />
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Path:" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" x:Name="PathText" FontFamily="Consolas" FontSize="11"
                             Opacity="0.75" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Size:" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" x:Name="SizeText" Opacity="0.75" VerticalAlignment="Center" />
                </Grid>
                <!-- Filesystem timestamps. Editable; metadata-only saves
                     keep these untouched (AtomicMetadataWrite restores
                     them) so backup / sync tools don't see false-positive
                     changes. The 📅 button at the right of each row stamps
                     all three with the detected capture date. -->
                <Grid ColumnDefinitions="80,Auto,Auto,Auto,*">
                  <TextBlock Grid.Column="0" Text="Created:" VerticalAlignment="Center" />
                  <DatePicker Grid.Column="1" x:Name="FileCreatedDate" Margin="0,0,4,0" />
                  <TimePicker Grid.Column="2" x:Name="FileCreatedTime" ClockIdentifier="24HourClock" />
                  <Button Grid.Column="3" Content="📅" Width="28" Padding="0" Margin="6,0,0,0"
                          Click="OnApplyCaptureDateToFileTimestampsClick"
                          ToolTip.Tip="Set Created, Modified and Accessed to the detected capture date" />
                </Grid>
                <Grid ColumnDefinitions="80,Auto,Auto,*">
                  <TextBlock Grid.Column="0" Text="Modified:" VerticalAlignment="Center" />
                  <DatePicker Grid.Column="1" x:Name="FileModifiedDate" Margin="0,0,4,0" />
                  <TimePicker Grid.Column="2" x:Name="FileModifiedTime" ClockIdentifier="24HourClock" />
                </Grid>
                <Grid ColumnDefinitions="80,Auto,Auto,*">
                  <TextBlock Grid.Column="0" Text="Accessed:" VerticalAlignment="Center" />
                  <DatePicker Grid.Column="1" x:Name="FileAccessedDate" Margin="0,0,4,0" />
                  <TimePicker Grid.Column="2" x:Name="FileAccessedTime" ClockIdentifier="24HourClock" />
                </Grid>
                <!-- Capture date: XMP DateCreated / EXIF DateTimeOriginal.
                     Picker = editable; hint shows which source seeded it so
                     the user sees where it came from (EXIF vs filename vs
                     file mtime). -->
                <Grid ColumnDefinitions="80,Auto,Auto,*">
                  <TextBlock Grid.Column="0" Text="Captured:" VerticalAlignment="Center"
                             ToolTip.Tip="XMP photoshop:DateCreated / EXIF DateTimeOriginal" />
                  <DatePicker Grid.Column="1" x:Name="CaptureDatePicker" Margin="0,0,4,0" />
                  <TimePicker Grid.Column="2" x:Name="CaptureTimePicker" ClockIdentifier="24HourClock" />
                  <TextBlock Grid.Column="3" x:Name="CaptureDateHint" VerticalAlignment="Center"
                             FontSize="11" Opacity="0.6" Margin="8,0,0,0" />
                </Grid>
                <Grid ColumnDefinitions="80,*,*,Auto">
                  <TextBlock Grid.Column="0" Text="GPS:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" x:Name="GpsLatBox" Watermark="Latitude" Margin="0,0,4,0" />
                  <TextBox Grid.Column="2" x:Name="GpsLonBox" Watermark="Longitude" Margin="0,0,4,0" />
                  <TextBox Grid.Column="3" x:Name="GpsAltBox" Watermark="Alt (m)" Width="80" />
                </Grid>
                <Grid ColumnDefinitions="80,120,Auto,*">
                  <TextBlock Grid.Column="0" Text="Direction:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" x:Name="DirectionBox" Watermark="0-360°" Margin="0,0,8,0" />
                  <ToggleButton Grid.Column="2" x:Name="DirectionMagneticCheck"
                                Content="🧲" Width="32" Height="28" Padding="0" FontSize="14"
                                ToolTip.Tip="Toggle on if the direction value is a magnetic compass bearing rather than true north" />
                </Grid>
                <Grid ColumnDefinitions="80,*,*">
                  <TextBlock Grid.Column="0" Text="Target:" VerticalAlignment="Center"
                             ToolTip.Tip="GPS point the camera was aimed at (exif:GPSDestLatitude/Longitude)" />
                  <TextBox Grid.Column="1" x:Name="TargetLatBox" Watermark="Target lat" Margin="0,0,4,0" />
                  <TextBox Grid.Column="2" x:Name="TargetLonBox" Watermark="Target lon" />
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Location:" VerticalAlignment="Center"
                             ToolTip.Tip="Sub-location: neighborhood, venue, road (Iptc4xmpCore:Location)" />
                  <TextBox Grid.Column="1" x:Name="LocationBox" Watermark="e.g. Times Square" />
                </Grid>
                <Grid ColumnDefinitions="80,*,80,*">
                  <TextBlock Grid.Column="0" Text="City:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" x:Name="CityBox" Margin="0,0,8,0" />
                  <TextBlock Grid.Column="2" Text="State:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" x:Name="StateBox" />
                </Grid>
                <Grid ColumnDefinitions="80,*,80,*">
                  <TextBlock Grid.Column="0" Text="Country:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" x:Name="CountryBox" Margin="0,0,8,0" />
                  <TextBlock Grid.Column="2" Text="Code:" VerticalAlignment="Center"
                             ToolTip.Tip="ISO 3166-1 alpha-2 country code (e.g. DE, US)" />
                  <TextBox Grid.Column="3" x:Name="CountryCodeBox" />
                </Grid>
                <!-- Picasa-style one-click rating: clicking a star sets the
                     rating; clicking the same star again clears it. The
                     ⊘ chip flags the photo as Rejected (XMP rating -1).
                     The lower row is a single-pick color label. -->
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Rating:" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <ToggleButton x:Name="EditRatingReject" Content="⊘" Width="28" Padding="0" FontSize="14"
                                  Classes="reject" Click="OnEditorRejectClick"
                                  ToolTip.Tip="Mark as Rejected (XMP rating -1)" />
                    <Border Width="6" />
                    <ToggleButton x:Name="EditStar1" Content="★" Width="26" Padding="0" FontSize="14"
                                  Classes="star" Click="OnEditorStarClick" Tag="1" />
                    <ToggleButton x:Name="EditStar2" Content="★" Width="26" Padding="0" FontSize="14"
                                  Classes="star" Click="OnEditorStarClick" Tag="2" />
                    <ToggleButton x:Name="EditStar3" Content="★" Width="26" Padding="0" FontSize="14"
                                  Classes="star" Click="OnEditorStarClick" Tag="3" />
                    <ToggleButton x:Name="EditStar4" Content="★" Width="26" Padding="0" FontSize="14"
                                  Classes="star" Click="OnEditorStarClick" Tag="4" />
                    <ToggleButton x:Name="EditStar5" Content="★" Width="26" Padding="0" FontSize="14"
                                  Classes="star" Click="OnEditorStarClick" Tag="5" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Label:" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3">
                    <ToggleButton x:Name="EditLabelRed"    Content="Red"    Padding="6,2" FontSize="11" FontWeight="SemiBold" Classes="label-red"    Click="OnEditorLabelClick" Tag="Red" />
                    <ToggleButton x:Name="EditLabelYellow" Content="Yellow" Padding="6,2" FontSize="11" FontWeight="SemiBold" Classes="label-yellow" Click="OnEditorLabelClick" Tag="Yellow" />
                    <ToggleButton x:Name="EditLabelGreen"  Content="Green"  Padding="6,2" FontSize="11" FontWeight="SemiBold" Classes="label-green"  Click="OnEditorLabelClick" Tag="Green" />
                    <ToggleButton x:Name="EditLabelBlue"   Content="Blue"   Padding="6,2" FontSize="11" FontWeight="SemiBold" Classes="label-blue"   Click="OnEditorLabelClick" Tag="Blue" />
                    <ToggleButton x:Name="EditLabelPurple" Content="Purple" Padding="6,2" FontSize="11" FontWeight="SemiBold" Classes="label-purple" Click="OnEditorLabelClick" Tag="Purple" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Keywords:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" x:Name="KeywordsBox" Watermark="comma-separated" />
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Title:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" x:Name="TitleBox" />
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Caption:" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" x:Name="CaptionBox" AcceptsReturn="True" TextWrapping="Wrap" Height="48" />
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Creator:" VerticalAlignment="Center"
                             ToolTip.Tip="Photographer / author — dc:creator, IPTC By-line, EXIF Artist" />
                  <TextBox Grid.Column="1" x:Name="CreatorBox" />
                </Grid>
                <Grid ColumnDefinitions="80,*">
                  <TextBlock Grid.Column="0" Text="Copyright:" VerticalAlignment="Center"
                             ToolTip.Tip="Copyright notice — dc:rights, IPTC Copyright, EXIF Copyright" />
                  <TextBox Grid.Column="1" x:Name="CopyrightBox" Watermark="© 2026 Your Name" />
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,4,0,0">
                  <Button Content="🔍" FontSize="14" Width="34" Height="30" Padding="0" Click="OnAutoDetectClick"
                          ToolTip.Tip="Auto-detect — runs the YOLO object detector and adds matching keywords to this file" />
                  <Button Content="↺" FontSize="14" Width="34" Height="30" Padding="0" Click="OnRevertMetadataClick"
                          ToolTip.Tip="Revert — discard unsaved edits and reload the editor from the file on disk" />
                  <Button Content="🗂" FontSize="14" Width="34" Height="30" Padding="0" Click="OnApplyToSelectionClick"
                          ToolTip.Tip="Apply to selection — write the current editor values to every selected file in the grid" />
                  <Button Content="💾" FontSize="16" Width="38" Height="30" Padding="0" FontWeight="Bold" Click="OnSaveMetadataClick"
                          Background="#1976D2" Foreground="White"
                          ToolTip.Tip="Save — write the current editor values to the previewed file" />
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,8,8,0" Spacing="6">
      <Button Content="🔍 Scan Files"       Click="OnScanClick"         IsEnabled="{Binding !IsProcessing}"
              ToolTip.Tip="Populate the grid from the active browse mode (Sources tree or Target directory)" />
      <!-- Run / Run-on-Directory only make sense when browsing the source
           tree — they ORGANIZE files into the target. Hidden in Target
           mode where the files are already organised. -->
      <Button Content="▶ Run"  FontWeight="Bold" Click="OnRunClick"    IsEnabled="{Binding !IsProcessing}"
              IsVisible="{Binding IsSourceMode}"
              ToolTip.Tip="Organize the files currently listed in the grid by date" />
      <Button Content="▶▶ Run on Directory" Click="OnRunDirectoryClick" IsEnabled="{Binding !IsProcessing}"
              IsVisible="{Binding IsSourceMode}"
              ToolTip.Tip="Walk every checked source directly, no pre-scan required" />
      <Button Content="⏹ Cancel"           Click="OnCancelClick"       IsEnabled="{Binding IsProcessing}" />
      <CheckBox Content="Recursive (Run on Directory)" Margin="24,0,0,0"
                IsChecked="{Binding Recursive, Mode=TwoWay}"
                IsVisible="{Binding IsSourceMode}" />
    </StackPanel>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="8,6,8,8">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <Border Background="#E8EDF2" CornerRadius="8" Padding="8,3">
          <TextBlock Text="{Binding PhotoCountSegment}" FontSize="12" />
        </Border>
        <Border Background="#E8EDF2" CornerRadius="8" Padding="8,3"
                IsVisible="{Binding HasActiveFilter}">
          <TextBlock Text="{Binding ActiveFilterSegment}" FontSize="12" />
        </Border>
        <Border Background="#E8EDF2" CornerRadius="8" Padding="8,3">
          <TextBlock Text="{Binding AcceleratorDevice}" FontSize="12" />
        </Border>
        <Border Background="#E8EDF2" CornerRadius="8" Padding="8,3">
          <TextBlock Text="{Binding CacheSizeDisplay}" FontSize="12" />
        </Border>
        <Border Background="#E8EDF2" CornerRadius="8" Padding="8,3"
                IsVisible="{Binding IsPreCaching}">
          <TextBlock Text="{Binding PreCacheDisplay}" FontSize="12" />
        </Border>
        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                   Opacity="0.7" FontSize="12" Margin="4,0,0,0" />
      </StackPanel>
      <ProgressBar Grid.Column="1" Width="240" Height="16"
                   Minimum="0" Maximum="100"
                   Value="{Binding ProgressValue}" />
    </Grid>

    <!-- D5: long-operation progress strip. Visible only while
         CurrentOperation is non-null; switches to indeterminate mode when
         the operation reports Fraction=NaN. The Cancel button only appears
         when the operation supplied a cancellation callback. -->
    <Border Grid.Row="4" Margin="8,0,8,8"
            BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4"
            Padding="8,4"
            IsVisible="{Binding HasCurrentOperation}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" DataContext="{Binding CurrentOperation}">
        <TextBlock Grid.Column="0" Text="{Binding Description}" VerticalAlignment="Center" Margin="0,0,8,0" />
        <ProgressBar Grid.Column="1" Height="14" Margin="0,0,8,0"
                     Minimum="0" Maximum="100"
                     Value="{Binding Percentage}"
                     IsIndeterminate="{Binding IsIndeterminate}" />
        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0"
                   Text="{Binding Percentage, StringFormat={}{0:0}%}"
                   IsVisible="{Binding !IsIndeterminate}" />
        <Button Grid.Column="3" x:Name="CancelOperationButton" Content="⏹ Cancel"
                Click="OnCancelOperationClick" Padding="8,2" />
      </Grid>
    </Border>
  </Grid>
</Window>
