<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:PhotoManager.UI.Models"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="PhotoManager.UI.Views.FaceGalleryWindow"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Title="Face gallery">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
      <TextBlock Text="Face gallery" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Opacity="0.75" TextWrapping="Wrap"
                 Text="Every tagged face in your currently scanned library. Faces with embeddings (ArcFace/MobileFaceNet) can be grouped by name — name a cluster and it propagates to every photo it contains. Merge clusters that belong to the same person; double-click a tile to unmerge faces that don't." />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
      <TextBlock Grid.Column="0" VerticalAlignment="Center" Opacity="0.75"
                 Text="Using the main window's scanned file list." />
      <CheckBox Grid.Column="1" x:Name="GroupByNameBox" Content="Group by name" IsChecked="True" VerticalAlignment="Center"
                ToolTip.Tip="When checked, faces sharing the exact same name merge into one cluster; unnamed faces are kept separate. When unchecked, every face is its own tile."
                Checked="OnGroupByNameChanged" Unchecked="OnGroupByNameChanged" />
    </Grid>

    <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
      <!-- Disable horizontal scroll so the WrapPanel inherits the viewport's
           width as its bound and wraps tiles onto new rows instead of
           extending indefinitely to the right. Vertical scrollbar handles
           overflow downward. -->
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="ClustersList" Padding="6">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="models:FaceClusterViewModel">
              <Border Width="220" Margin="4" BorderBrush="{DynamicResource TileBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource TileSurfaceBrush}"
                      DoubleTapped="OnClusterDoubleTapped" Tag="{CompiledBinding}"
                      ToolTip.Tip="Double-click to inspect every face in this group and unmerge faces that don't belong.">
                <StackPanel>
                  <Border Height="160" Background="{DynamicResource ThumbBackgroundBrush}">
                    <Image Source="{CompiledBinding Thumbnail}" Stretch="Uniform" />
                  </Border>
                  <StackPanel Margin="8" Spacing="4">
                    <TextBlock Text="{CompiledBinding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{CompiledBinding CountText}" FontSize="11" Opacity="0.7" />
                    <TextBox Text="{CompiledBinding Name, Mode=TwoWay}" Watermark="(enter name)" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <CheckBox Content="select" IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}" FontSize="11" />
                      <Button Content="Apply name" FontSize="11" Padding="6,2" Click="OnApplyNameClick" Tag="{CompiledBinding}" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
      <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" Opacity="0.75" />
      <Button Grid.Column="1" Content="🔗 Merge selected" Click="OnMergeSelectedClick" />
      <Button Grid.Column="2" Content="🚪 Close" Margin="6,0,0,0" Click="OnCloseClick" IsCancel="True" />
    </Grid>
  </Grid>
</Window>
